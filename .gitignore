# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# raw audio / DAW project files (never commit – only MP3 demos under
# public/assets/audio/demos/ are allowed)
*.wav
*.aiff
*.aif
*.flac
*.m4a
*.logicx
*.als
*.band

# explicit allowlist for the public demo MP3s
!public/assets/audio/demos/*.mp3
